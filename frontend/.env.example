# MyLMS Frontend — Environment Variables Template
# Copy to .env.local for local overrides or .env.production for production builds.

# Override the API base URL if the API lives on a different domain/subdomain.
# Leave blank if using same-domain deployment (recommended).
# Example (cross-domain): VITE_API_BASE_URL=https://api.yourdomain.com
VITE_API_BASE_URL=
