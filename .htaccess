# ============================================================
# MyLMS — Production Apache Router
# ============================================================
# Architecture:
#   /api/*       → web/backend/public/ (Laravel)
#   /sanctum/*   → web/backend/public/ (Laravel Sanctum)
#   /*           → web/frontend/dist/  (React SPA)
# ============================================================

<IfModule mod_rewrite.c>
    RewriteEngine On

    # ----------------------------------------------------------
    # 1. Force HTTPS
    # ----------------------------------------------------------
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [L,R=301]

    # ----------------------------------------------------------
    # 2. Block access to sensitive files
    # ----------------------------------------------------------
    RewriteRule ^(\.env|artisan|composer\.(json|lock)|package(-lock)?\.json)$ - [F,L]
    RewriteRule ^web/backend/(\.env|artisan|composer\.(json|lock))$ - [F,L]
</IfModule>

# ----------------------------------------------------------
# 3. Security Headers
# ----------------------------------------------------------
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS

    # Remove server fingerprint headers
    Header unset X-Powered-By
    Header always unset X-Powered-By
</IfModule>

# ----------------------------------------------------------
# 4. Compression
# ----------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE text/javascript application/javascript application/json
    AddOutputFilterByType DEFLATE application/x-font-ttf font/opentype image/svg+xml
</IfModule>

# ----------------------------------------------------------
# 5. Browser Caching for Static Assets
# ----------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# ----------------------------------------------------------
# 6. Routing
# ----------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Laravel API — forward to web/backend/public/
    RewriteCond %{REQUEST_URI} ^/api/ [NC]
    RewriteRule ^(.*)$ web/backend/public/$1 [L,QSA]

    # Laravel Sanctum CSRF Cookie
    RewriteCond %{REQUEST_URI} ^/sanctum/ [NC]
    RewriteRule ^(.*)$ web/backend/public/$1 [L,QSA]

    # Pass Authorization headers so Sanctum tokens work
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Serve real static files from web/frontend/dist/
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{DOCUMENT_ROOT}/web/frontend/dist%{REQUEST_URI} -f
    RewriteRule ^(.*)$ web/frontend/dist/$1 [L]

    # Serve real directories from web/frontend/dist/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{DOCUMENT_ROOT}/web/frontend/dist%{REQUEST_URI} -d
    RewriteRule ^(.*)$ web/frontend/dist/$1 [L]

    # SPA fallback — everything else → React index.html
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(?!api|sanctum|web/backend)(.*)$ web/frontend/dist/index.html [L]
</IfModule>
