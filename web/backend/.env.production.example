# =============================================================================
# MyLMS — Production Environment Template
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file to .env on your production server
#   2. Fill in every value marked with <YOUR_...>
#   3. NEVER commit the real .env to version control
#   4. Run: php artisan config:cache && php artisan route:cache after changes
# =============================================================================

APP_NAME="MyLMS"
APP_ENV=production
APP_KEY=<RUN: php artisan key:generate --show>
APP_DEBUG=false
APP_URL=https://<YOUR_DOMAIN>
APP_TIMEZONE=UTC

FRONTEND_URL=https://<YOUR_DOMAIN>

# =============================================================================
# SANCTUM — Must match your production domain exactly
# =============================================================================
SANCTUM_STATEFUL_DOMAINS=<YOUR_DOMAIN>

# =============================================================================
# LOGGING — Use 'error' in production (not 'debug')
# =============================================================================
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# =============================================================================
# DATABASE — PostgreSQL
# =============================================================================
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=<YOUR_DB_NAME>
DB_USERNAME=<YOUR_DB_USER>
DB_PASSWORD=<YOUR_DB_PASSWORD>

# =============================================================================
# SESSION — Must use your production domain
# =============================================================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.<YOUR_DOMAIN>

# =============================================================================
# QUEUE — Use database queue (or switch to Redis for high traffic)
# =============================================================================
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log

# =============================================================================
# CACHE — Use database cache (or Redis)
# =============================================================================
CACHE_STORE=database
# For Redis-based cache (recommended for production):
# CACHE_STORE=redis

# =============================================================================
# REDIS (Optional but recommended for production performance)
# =============================================================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=<YOUR_REDIS_PASSWORD_OR_null>
REDIS_PORT=6379

# =============================================================================
# MAIL — Configure your production mail provider
# =============================================================================
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=<YOUR_SMTP_HOST>
MAIL_PORT=587
MAIL_USERNAME=<YOUR_SMTP_USERNAME>
MAIL_PASSWORD=<YOUR_SMTP_PASSWORD>
MAIL_FROM_ADDRESS="noreply@<YOUR_DOMAIN>"
MAIL_FROM_NAME="${APP_NAME}"

# Popular providers:
#   Mailgun:    mail.mailgun.org / port 587
#   Resend:     smtp.resend.com  / port 465
#   Gmail SMTP: smtp.gmail.com   / port 587

# =============================================================================
# PAYMENT GATEWAYS
# =============================================================================

# Paystack (Nigerian / African market)
PAYSTACK_SECRET_KEY=<YOUR_PAYSTACK_SECRET_KEY>
PAYSTACK_PUBLIC_KEY=<YOUR_PAYSTACK_PUBLIC_KEY>
PAYSTACK_WEBHOOK_SECRET=<YOUR_PAYSTACK_WEBHOOK_SECRET>

# Stripe (International)
STRIPE_SECRET_KEY=<YOUR_STRIPE_SECRET_KEY>
STRIPE_PUBLIC_KEY=<YOUR_STRIPE_PUBLIC_KEY>
STRIPE_WEBHOOK_SECRET=<YOUR_STRIPE_WEBHOOK_SECRET>

# =============================================================================
# FILE STORAGE — Use S3-compatible storage in production
# =============================================================================
FILESYSTEM_DISK=local
# For AWS S3 (recommended for scalability):
# FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=<YOUR_AWS_ACCESS_KEY>
AWS_SECRET_ACCESS_KEY=<YOUR_AWS_SECRET_KEY>
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=<YOUR_S3_BUCKET_NAME>
AWS_USE_PATH_STYLE_ENDPOINT=false

# =============================================================================
# SECURITY
# =============================================================================
BCRYPT_ROUNDS=12
APP_MAINTENANCE_DRIVER=file

# =============================================================================
# LOCALE
# =============================================================================
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# =============================================================================
# VITE (Frontend build reference — not used in PHP runtime)
# =============================================================================
VITE_APP_NAME="${APP_NAME}"
